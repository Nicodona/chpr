# CHPR Resources Hub — PRODUCTION env template.
#
# Copy to /opt/chpr/.env on the droplet and fill in the real values. This
# file is read BOTH by docker compose (for ${POSTGRES_*} interpolation) and
# as the web container's env_file. NEVER commit the real .env.

# --- Django core ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE-ME-long-random-string
DEBUG=False
ALLOWED_HOSTS=chpr-resource.org,www.chpr-resource.org,127.0.0.1,localhost

# --- Reverse-proxy / CSRF (required for login behind Apache HTTPS) ---
BEHIND_TLS_PROXY=True
CSRF_TRUSTED_ORIGINS=https://chpr-resource.org,https://www.chpr-resource.org

# --- Database (the postgres service; host is the compose service name) ---
POSTGRES_DB=chpr_hub
POSTGRES_USER=chpr
POSTGRES_PASSWORD=CHANGE-ME-strong-db-password
DATABASE_URL=postgres://chpr:CHANGE-ME-strong-db-password@postgres:5432/chpr_hub

# --- CORS (same-origin in prod; keep empty/minimal) ---
CORS_ALLOWED_ORIGINS=https://chpr-resource.org

# --- Public site URL (used in email links) ---
SITE_URL=https://chpr-resource.org

# --- Email (optional; console backend if unset) ---
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=CHPR Resources Hub <noreply@chprhealth.org>
