# Copy to .env and adjust. Read automatically by django-environ on startup.

# Security
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# PostgreSQL connection (postgres://USER:PASSWORD@HOST:PORT/DBNAME)
DATABASE_URL=postgres://chpr:chpr@localhost:5432/chpr_hub

# Origins allowed to call the API from a different origin (Vite dev server)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
